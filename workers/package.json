{
  "name": "mobin-store-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute mobin-store-db --file=./schema.sql",
    "db:migrate": "wrangler d1 execute mobin-store-db --file=./migrations/latest.sql",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.5.2",
    "wrangler": "^3.78.12"
  }
}
